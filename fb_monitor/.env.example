# Required: Telegram
TELEGRAM_BOT_TOKEN=123456789:your_bot_token
TELEGRAM_CHAT_ID=123456789

# Required: Chrome profile path used by Playwright persistent context
CHROME_USER_DATA_DIR=/path/to/your/chrome/user/data

# Required: Ollama Cloud endpoint + auth
OLLAMA_API_BASE_URL=https://your-ollama-endpoint
OLLAMA_API_KEY=your_ollama_cloud_api_key

# Optional: model and timeout
OLLAMA_MODEL=minimax/m2.5
OLLAMA_TIMEOUT_SEC=30

# Optional: logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: global location filter (used in search URL)
LATITUDE=49.2827
LONGITUDE=-123.1207
RADIUS_KM=50
